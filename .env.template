# API Keys for different databases
# Copy this file to .env and replace with your actual API keys

# PubMed API Key and Email (email is required by NCBI)
PUBMED_API_KEY=your_pubmed_api_key_here
PUBMED_EMAIL=your_email@example.com

# Cochrane API Key
COCHRANE_API_KEY=your_cochrane_api_key_here

# Scopus API Key
SCOPUS_API_KEY=your_scopus_api_key_here

# Embase API Key
EMBASE_API_KEY=your_embase_api_key_here

# Other configuration parameters
OUTPUT_DIR=output
DATA_DIR=data
